{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "lib": ["ES2020"],
        "strict": false,
        "esModuleInterop": true,
        "allowJs": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "outDir": "./dist",
        "rootDir": "."
    },
    "include": ["./**/*.ts"],
    "exclude": ["node_modules", "dist"],
    "ts-node": {
        "files": true,
        "transpileOnly": true
    }
}
